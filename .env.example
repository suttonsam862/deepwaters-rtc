# Copy this file to ".env" and fill in the values. ".env" is gitignored.
SESSION_SECRET="a-long-random-string"
PUBLIC_STORE_DOMAIN="mock.shop"          # replaced automatically when you link the real store

# Supabase (the coaching ledger database) — Supabase > Project Settings > API
PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"
